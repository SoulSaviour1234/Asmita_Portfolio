{
  "experimentalServices": {
    "frontend": {
      "framework": "create-react-app",
      "installCommand": "npm install --legacy-peer-deps",
      "root": "frontend",
      "routePrefix": "/"
    },
    "backend": {
      "builder": "@vercel/python",
      "entrypoint": "backend/server.py",
      "routePrefix": "/_/backend"
    }
  }
}
